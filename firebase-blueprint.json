{
  "entities": {
    "Bot": {
      "title": "Bot Instance",
      "description": "Configuration and state for a Telegram bot instance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "token": { "type": "string" },
        "name": { "type": "string" },
        "config": {
          "type": "object",
          "properties": {
            "systemPrompt": { "type": "string" },
            "temperature": { "type": "number" },
            "maxHistory": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "token", "name", "config"]
    }
  },
  "firestore": {
    "bots/{botId}": {
      "schema": "Bot",
      "description": "Collection of managed bot instances."
    }
  }
}
