rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /bots/{botId} {
      allow read, write: if true; // Geliştirme aşamasında her şeye izin ver, dashboard üzerinden yönetim için.
    }
  }
}
